---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Base
  title={post.data.title}
  description={post.data.description}
  ogImage={post.data.ogImage}
  ogImageAlt={post.data.ogImage ? post.data.title : undefined}
>
  <article>
    {post.data.eyebrow && <p class="eyebrow">{post.data.eyebrow}</p>}
    <h1>{post.data.title}</h1>
    {
      post.data.meta && post.data.meta.length > 0 ? (
        <p class="meta-line">
          {post.data.meta.join(' · ')}
          {' · '}
          {post.data.pubDate.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </p>
      ) : (
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </time>
      )
    }
    <div class="content">
      <Content />
    </div>
  </article>
</Base>

<style>
  .eyebrow {
    color: var(--accent);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 0.5rem;
  }

  time,
  .meta-line {
    display: block;
    color: var(--muted);
    font-size: 0.875rem;
    margin-bottom: 2rem;
  }

  .content :global(h2) {
    margin-top: 2rem;
  }

  .content :global(a) {
    color: var(--accent);
  }

  .content :global(.table-wrap) {
    max-width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin: 1.5rem 0;
  }

  .content :global(table) {
    min-width: 480px;
    border-collapse: collapse;
    font-size: 0.95rem;
  }

  .content :global(th) {
    text-align: left;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    color: var(--muted);
    padding: 0.6rem 1rem;
    white-space: nowrap;
    border-bottom: 1px solid color-mix(in srgb, var(--fg) 15%, transparent);
  }

  .content :global(td) {
    padding: 0.75rem 1rem;
    vertical-align: top;
    border-bottom: 1px solid color-mix(in srgb, var(--fg) 8%, transparent);
  }

  .content :global(tr:last-child td) {
    border-bottom: none;
  }

  .content :global(.tool-badge) {
    display: inline-block;
    font-family: ui-monospace, 'SF Mono', 'JetBrains Mono', Menlo, Consolas, monospace;
    font-size: 0.85em;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    white-space: nowrap;
    border: 1px solid transparent;
  }

  .content :global(.tool-cli) {
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 15%, transparent);
    border-color: color-mix(in srgb, var(--accent) 45%, transparent);
  }

  .content :global(.tool-mcp) {
    color: var(--accent-2);
    background: color-mix(in srgb, var(--accent-2) 15%, transparent);
    border-color: color-mix(in srgb, var(--accent-2) 45%, transparent);
  }

  /* Convention: a post's first ## section is its TL;DR / verdict, rendered
     as a callout card with the following list laid out as two columns. */
  .content :global(h2:first-of-type) {
    margin: 0;
    border: 1px solid color-mix(in srgb, var(--accent) 35%, transparent);
    border-bottom: none;
    border-radius: 6px 6px 0 0;
    background: color-mix(in srgb, var(--accent) 6%, transparent);
    padding: 0.9rem 1.25rem 0.5rem;
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .content :global(h2:first-of-type + ul) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem 2rem;
    list-style: none;
    margin: 0 0 2rem;
    padding: 0.25rem 1.25rem 1.25rem;
    border: 1px solid color-mix(in srgb, var(--accent) 35%, transparent);
    border-top: none;
    border-radius: 0 0 6px 6px;
    background: color-mix(in srgb, var(--accent) 6%, transparent);
  }

  .content :global(h2:first-of-type + ul li) {
    position: relative;
    padding: 0.6rem 0 0.6rem 1.1rem;
  }

  .content :global(h2:first-of-type + ul li::before) {
    content: '';
    position: absolute;
    left: 0;
    top: 1rem;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
  }

  .content :global(h2:first-of-type + ul li:nth-child(2n)::before) {
    background: var(--accent-2);
  }

  .content :global(h2:first-of-type + ul li strong:first-child) {
    display: block;
    color: var(--fg);
    font-size: 1rem;
    margin-bottom: 0.25rem;
  }

  @media (max-width: 640px) {
    .content :global(h2:first-of-type + ul) {
      grid-template-columns: 1fr;
    }
  }
</style>
