---
import Base from '../layouts/Base.astro';

const timeline = [
  {
    year: '2026-present',
    title: 'Senior Site Reliability Engineer, ID.me',
    detail: 'Authoring standardized Terraform modules org-wide and cutting workspace plan/apply runtime ~45% through dependency and state optimization.',
  },
  {
    year: '2024-2026',
    title: 'Cloud Engineer IV, ID.me',
    detail: 'Led platform migration from Nomad to Kubernetes across 5 production GKE clusters and Terraform Enterprise from VMs to Kubernetes with full GitOps and observability.',
  },
  {
    year: '2022-2024',
    title: 'Cloud Engineer III, ID.me',
    detail: 'Operated Vault, Consul, and Nomad across GCP and AWS; built an artifact management platform on Kubernetes from the ground up.',
  },
  {
    year: '2015-2022',
    title: 'Linux Systems Administrator to Linux Engineer, U.S. Office of Personnel Management',
    detail: 'Contractor (Business Operational Concepts, then CSRA). Progressed from Tier 2 NOC support to Tier 3 team lead across RHEL, Azure hybrid infrastructure, Red Hat Satellite/Identity Manager, and Puppet/Ansible automation.',
  },
  {
    year: '2009-2015',
    title: 'Early career: systems and network administration',
    detail: 'Network Administrator (Secura), Systems Administrator (Wellness Works), IT Work Study (Butler CCC), Tech Associate (Staples), and Lead Installation Technician (Kb Port): hands-on Linux/Windows server and workstation support, network hardening, and backups.',
  },
];
---

<Base title="Jordan English">
  <section class="about">
    <p class="prompt">$ whoami</p>
    <h1>Jordan English<span class="cursor" aria-hidden="true"></span></h1>
    <p class="tagline">Senior Site Reliability Engineer</p>
    <p>
      Senior SRE with 10+ years of progressive infrastructure experience, including
      4+ years at ID.me building and operating the core platform that supports
      identity verification at scale. I specialize in container orchestration,
      secrets management, service mesh, and infrastructure as code across multi-cloud
      environments (GKE, GCP, AWS), with deep hands-on experience in Kubernetes,
      Vault, Consul, Nomad, and Terraform Enterprise.
    </p>
    <p>
      I'm driven by the SRE philosophy: reduce toil through automation, build
      reliability through observability, and improve systems through rigorous
      post-incident learning. Beyond the technical work, I care about mentorship and
      helping engineers navigate complex systems and deliver work they're proud of.
    </p>
  </section>

  <section class="timeline">
    <p class="prompt">$ history</p>
    <h2>Timeline</h2>
    <ol>
      {
        timeline.map((entry) => (
          <li>
            <span class="year">{entry.year}</span>
            <span class="entry-title">{entry.title}</span>
            <p class="detail">{entry.detail}</p>
          </li>
        ))
      }
    </ol>
  </section>
</Base>

<style>
  .prompt {
    color: var(--accent);
    margin: 0 0 0.25rem;
    font-size: 0.875rem;
  }

  .tagline {
    color: var(--muted);
    font-size: 1.1rem;
  }

  .cursor {
    display: inline-block;
    width: 0.55ch;
    height: 1em;
    margin-left: 0.15em;
    background: var(--accent);
    vertical-align: -0.15em;
    animation: blink 1s step-end infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .cursor {
      animation: none;
    }
  }

  @keyframes blink {
    0%,
    50% {
      opacity: 1;
    }
    50.01%,
    100% {
      opacity: 0;
    }
  }

  .timeline ol {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .timeline li {
    padding: 1rem 0;
    border-top: 1px solid color-mix(in srgb, var(--fg) 12%, transparent);
    display: grid;
    grid-template-columns: 7rem 1fr;
    gap: 0.5rem 1rem;
  }

  .year {
    color: var(--muted);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .entry-title {
    font-weight: 600;
  }

  .detail {
    grid-column: 2;
    margin: 0;
    color: var(--muted);
  }
</style>
