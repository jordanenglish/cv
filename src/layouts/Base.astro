---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'CV and blog' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <nav>
        <a href={import.meta.env.BASE_URL}>$ home</a>
        <a href={`${import.meta.env.BASE_URL}blog/`}>$ blog</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>&copy; {new Date().getFullYear()}</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark light;
    --max-width: 42rem;
    --fg: #e6edf3;
    --bg: #0d1117;
    --muted: #8b949e;
    --accent: #3fb950;
  }

  @media (prefers-color-scheme: light) {
    :root {
      --fg: #1f2328;
      --bg: #f6f8fa;
      --muted: #57606a;
      --accent: #1a7f37;
    }
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family: ui-monospace, 'SF Mono', 'JetBrains Mono', Menlo, Consolas, 'Liberation Mono',
      monospace;
    color: var(--fg);
    background: var(--bg);
    line-height: 1.6;
  }

  main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  a {
    color: var(--accent);
  }

  .site-header {
    border-bottom: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
  }

  .site-header nav {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1.25rem 1.5rem;
    display: flex;
    gap: 1.5rem;
  }

  .site-header nav a {
    text-decoration: none;
    font-weight: 600;
    color: var(--fg);
  }

  .site-header nav a:hover {
    color: var(--accent);
  }

  .site-footer {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1.5rem;
    color: var(--muted);
    font-size: 0.875rem;
  }
</style>
